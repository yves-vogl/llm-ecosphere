# Coverage scope for the CI gate: the core library. The CLI entry points
# below need trained checkpoints (train/evaluate/sample/inspect_attention/
# arena) or a terminal (play, and arena --vs human) — they are exercised by
# the pipeline itself (`make all`), the arena's own hermetic tests, and the
# CI corpus smoke test, not by full unit coverage. Including their
# interactive and checkpoint-loading paths would move the number with CLI
# size instead of core-library test quality.
[run]
omit =
    minillm/train.py
    minillm/evaluate.py
    minillm/play.py
    minillm/sample.py
    minillm/inspect_attention.py
    minillm/arena.py
    minillm/rl.py
